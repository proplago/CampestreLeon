{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('super').val() === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('super').val() === true)",
        ".write": "auth != null && ( root.child('users').child(auth.uid).child('super').val() === true || (auth.uid === $uid && !newData.hasChild('super') && !newData.hasChild('leagues')) )"
      }
    },
    "leagues": {
      "$lid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
