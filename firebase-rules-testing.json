{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('super').val() === true)",
        "super": {
          ".write": "root.child('users').child(auth.uid).child('super').val() === true"
        }
      }
    },
    "leagues": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
