{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('super').val() === true)",
        "super": {
          ".validate": "root.child('users').child(auth.uid).child('super').val() === true"
        }
      }
    },
    "leagueMembers": {
      "$lid": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin' || (auth.uid === $uid && !data.exists() && newData.child('role').val() === 'regular') || (auth.uid === $uid && !data.exists() && !root.child('leagueMembers').child($lid).exists()))",
          "role": {
            ".validate": "newData.val() === 'regular' || newData.val() === 'admin'"
          }
        }
      }
    },
    "leagues": {
      "$lid": {
        ".read": "auth != null",
        "players": {
          "$pid": {
            ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin' || newData.child('uid').val() === auth.uid || (data.exists() && data.child('uid').val() === auth.uid))"
          }
        },
        "days":        { ".write": "auth != null" },
        "ventajas":    { ".write": "auth != null" },
        "ventReq":     { ".write": "auth != null" },
        "ventHistory": { ".write": "auth != null" },
        "dblHistory":  { ".write": "auth != null" },
        "order":       { ".write": "auth != null" },
        "rules":       { ".write": "auth != null" },
        "meta":        { ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin')" },
        "courses":     { ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin')" },
        "units":       { ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin')" },
        "castigos":    { ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin')" },
        "houseRules":  { ".write": "auth != null && (root.child('users').child(auth.uid).child('super').val() === true || root.child('leagueMembers').child($lid).child(auth.uid).child('role').val() === 'admin')" }
      }
    }
  }
}
